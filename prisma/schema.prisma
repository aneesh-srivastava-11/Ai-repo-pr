generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Repository {
  id           Int      @id // GitHub Repo ID
  name         String
  fullName     String
  owner        String
  installation Int      // GitHub App Installation ID
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  pullRequests PullRequest[]
}

model PullRequest {
  id           Int      @id // GitHub PR ID
  number       Int
  title        String
  state        String
  headSha      String
  repositoryId Int
  repository   Repository @relation(fields: [repositoryId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  analyses     Analysis[]
}

model Analysis {
  id            String   @id @default(uuid())
  pullRequestId Int
  commitSha     String
  riskScore     Int
  summary       String
  reasons       String[]
  checklist     String[]
  createdAt     DateTime @default(now())

  pullRequest   PullRequest @relation(fields: [pullRequestId], references: [id])

  @@unique([pullRequestId, commitSha])
}
